{
  "//": [
    "Discussion on how to write comments in package.json:",
    "https://stackoverflow.com/questions/14221579/how-do-i-add-comments-to-package-json-for-npm-install"
  ],
  "name": "contact-api",
  "version": "1.0.0",
  "description": "Contact Form API",
  "type": "module",
  "// scripts": [
    "test:unit — Unit テスト（ドメイン層 + アプリケーション層、DB 不要）",
    "test:db   — DB テスト（インフラ層 + プレゼンテーション層、PostgreSQL 必要）"
  ],
  "scripts": {
    "clean": "node -e \"var fs = require('fs'); try{['dist','node_modules'].map((fpath) => fs.rmdirSync(fpath, { recursive: true }))}catch(err){console.log(err)}; process.exit(0);\"",
    "build": "tsc -b -v --listFiles",
    "start": "node dist/src/bin/server.js",
    "dev": "node --watch dist/src/bin/server.js | pino-pretty",
    "lint": "eslint .",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:db": "vitest run --project db",
    "migrate": "node dist/src/bin/migrate.js up --log-level info | pino-pretty",
    "migrate:down": "node dist/src/bin/migrate.js down --log-level info | pino-pretty",
    "seed": "node dist/src/bin/seed.js up --log-level info | pino-pretty",
    "seed:down": "node dist/src/bin/seed.js down --log-level info | pino-pretty"
  },
  "author": "",
  "license": "Unlicense",
  "dependencies": {
    "commander": "^14.0.3",
    "fastify": "^5.3.3",
    "kysely": "^0.28.0",
    "pg": "^8.13.0",
    "pino": "^10.3.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.11.0",
    "eslint": "^10.1.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.2.1"
  }
}
